{
	"name": "@techlestial/uilerial",
	"version": "2.0.0",
	"description": "Uilerial — professional React UI component library for Techlestial Labs. 30+ components, CSS Modules, TypeScript.",
	"private": false,
	"homepage": "https://uilerial.vercel.app",
	"main": "dist/index.js",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"sideEffects": ["**/*.css"],
	"files": ["dist", "README.md", "LICENSE"],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/techlestial/uilerial.git"
	},
	"publicUrl": "https://uilerial.vercel.app",
	"scripts": {
		"start": "react-scripts start",
		"build": "react-scripts build",
		"build:vercel": "cross-env PUBLIC_URL=/demo react-scripts build && node scripts/merge-marketing.mjs",
		"component:build": "rimraf dist && tsc && node scripts/import-css-modules.js && node scripts/copy-styles.mjs",
		"test": "react-scripts test --watchAll=false --passWithNoTests",
		"eject": "react-scripts eject",
		"release": "npm run component:build && npm publish --access public",
		"clean": "rimraf node_modules dist"
	},
	"eslintConfig": {
		"extends": "react-app"
	},
	"browserslist": {
		"production": [">0.2%", "not dead", "not op_mini all"],
		"development": ["last 1 chrome version", "last 1 firefox version", "last 1 safari version"]
	},
	"peerDependencies": {
		"react": ">=18.0.0",
		"react-dom": ">=18.0.0"
	},
	"devDependencies": {
		"@testing-library/jest-dom": "^4.2.4",
		"@testing-library/react": "^9.3.2",
		"@testing-library/user-event": "^7.1.2",
		"@types/lodash": "^4.14.161",
		"@types/node": "^22.7.7",
		"@types/react": "^18.3.11",
		"@types/react-dom": "^18.3.1",
		"cross-env": "^7.0.3",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-scripts": "5.0.1",
		"rimraf": "^6.1.3",
		"typescript": "^4.9.4",
		"typescript-plugin-css-modules": "^5.0.0"
	},
	"author": "m3yevn",
	"license": "MIT",
	"keywords": [
		"uilerial",
		"techlestial",
		"react",
		"ui",
		"component-library",
		"css-modules",
		"design-system"
	],
	"dependencies": {
		"jwt-decode": "^4.0.0"
	}
}
