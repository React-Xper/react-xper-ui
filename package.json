{
	"name": "@techlestial/uilerial",
	"version": "1.4.0",
	"description": "Uilerial — production React components for the Techlestial studio (CSS Modules, TypeScript-friendly).",
	"private": false,
	"homepage": "https://uilerial.vercel.app/demo",
	"main": "dist",
	"files": ["dist", "README.md", "LICENSE"],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/techlestial/uilerial.git"
	},
	"publicUrl": "https://uilerial.vercel.app",
	"scripts": {
		"start": "react-scripts start",
		"build": "react-scripts build",
		"build:vercel": "cross-env PUBLIC_URL=/demo react-scripts build && node scripts/merge-marketing.mjs",
		"component:build": "rimraf dist && mkdir dist && tsc && node scripts/import-css-modules.js",
		"test": "react-scripts test",
		"eject": "react-scripts eject",
		"release": "npm publish --access public",
		"clean": "rimraf node_modules"
	},
	"eslintConfig": {
		"extends": "react-app"
	},
	"browserslist": {
		"production": [">0.2%", "not dead", "not op_mini all"],
		"development": ["last 1 chrome version", "last 1 firefox version", "last 1 safari version"]
	},
	"devDependencies": {
		"@testing-library/jest-dom": "^4.2.4",
		"@testing-library/react": "^9.3.2",
		"@testing-library/user-event": "^7.1.2",
		"@types/lodash": "^4.14.161",
		"@types/node": "^22.7.7",
		"@types/react": "^18.3.11",
		"@types/react-dom": "^18.3.1",
		"cross-env": "^7.0.3",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-scripts": "5.0.1",
		"rimraf": "^6.1.3",
		"typescript": "^4.9.4",
		"typescript-plugin-css-modules": "^5.0.0"
	},
	"author": "m3yevn",
	"keywords": ["uilerial", "techlestial", "react", "ui", "css-modules"],
	"dependencies": {
		"jwt-decode": "^4.0.0"
	}
}
